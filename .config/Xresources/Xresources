#include "./colorschemes/matteblack.Xresources"

! urxvt
URxvt*buffered: true
URxvt*cursorBlink: true
URxvt*underlineColor: yellow
URxvt*font:  xft:JetBrains Mono:size=14:antialias=true
URxvt*depth: 32
URxvt*borderless: 1
URxvt*scrollBar: false
URxvt*loginShell: true
Urxvt*secondaryScroll:  true    # Enable Shift-PageUp/Down in screen
URxvt*saveLines: 5000
URxvt*termName: rxvt-unicode
URxvt.perl-ext-common: default,matcher
URxvt.urlLauncher: firefox
URxvt.matcher.button: 1

! sk / dmenu
dmenu.font:  xft:JetBrainsMono:size=12:antialias=true
dmenu.background: CLR_BACKGROUND
dmenu.foreground: CLR_FOREGROUND
dmenu.selbackground: CLR_PRIMARY
dmenu.selforeground: CLR_BACKGROUND
dmenu.normhighlightforeground: CLR_SECONDARY
dmenu.selhighlightforeground: CLR_SECONDARY

! st
st.font: JetBrainsMono:size=13:antialias=true:autohint=true
st.background: CLR_BACKGROUND
st.foreground: CLR_FOREGROUND
st.color12: CLR_SUBTEXT
st.color4:  CLR_SUBTEXT

! dwm
dwm.normbordercolor: CLR_BACKGROUND
dwm.selbordercolor: CLR_PRIMARY

dwm.normbgcolor: CLR_BACKGROUND
dwm.normfgcolor: CLR_FOREGROUND

dwm.selbgcolor: CLR_PRIMARY
dwm.selfgcolor: CLR_BACKGROUND

! qtile
qtile.bg: CLR_BACKGROUND
qtile.fg: CLR_FOREGROUND
qtile.pr: CLR_PRIMARY
qtile.sb: CLR_SUBTEXT

! xmonad
xmonad.normalBorderColor: CLR_BACKGROUND
xmonad.focusedBorderColor: CLR_PRIMARY
xmonad.bgColor: CLR_BACKGROUND
xmonad.fgColor: CLR_FOREGROUND
