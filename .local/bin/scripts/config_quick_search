#!/bin/bash

declare -A apps=(
    [kitty]="$HOME/.config/kitty/kitty.conf"
    [zsh]="$HOME/.zshrc"
    [nvim]="$HOME/.config/nvim/"
    [rofi]="$HOME/.local/share/rofi/"
    [hyprland]="$HOME/.config/hypr/"
)

options=""
for key in "${!apps[@]}"; do
    options+="$key\n"
done

esc=$(echo -e "$options" | dmenu -p "Edit config:" | xargs)
[[ -z "$esc" ]] && exit 0

target="${apps[$esc]}"

if [[ -z "$target" ]]; then
    echo "${esc} is not an option."
    exit 0
fi

$TERMINAL -d $target -e nvim "$target"
