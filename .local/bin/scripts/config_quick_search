#!/bin/bash

THEME="$HOME/.config/rofi/noctalia-theme.rasi"

get_icon() {
    local name="$1"
    icon=$(find /usr/share/icons ~/.local/share/icons -name "${name}.png" -o -name "${name}.svg" 2>/dev/null | head -1)
    if [[ -n "$icon" ]]; then
        echo "$name"
    else
        echo "text-editor"
    fi
}

options="kitty\0icon\x1f$(get_icon kitty)\nzsh\0icon\x1f$(get_icon zsh)\nnvim\0icon\x1f$(get_icon nvim)\nrofi\0icon\x1f$(get_icon rofi)\nhyprland\0icon\x1f$(get_icon hyprland)"

esc=$(echo -e "$options" | rofi -dmenu -p "Edit config" -theme "$THEME" | xargs)

case "${esc#* }" in
    vifm)
        esc="$HOME/.config/vifm/vifmrc"
        ;;
    kitty)
        esc="$HOME/.config/kitty/kitty.conf"
        ;;
    zsh)
        esc="$HOME/.zshrc"
        ;;
    nvim)
        esc="$HOME/.config/nvim/"
        ;;
    rofi)
        esc="$HOME/.local/share/rofi/"
        ;;
    hyprland)
        esc="$HOME/.config/hypr/"
        ;;
    *)
        exit 0
        ;;
esac

$TERMINAL -e nvim "$esc"
