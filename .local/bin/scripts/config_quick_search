#!/bin/sh

choice=$(
	printf "%s\n" \
		"kitty" \
		"zsh" \
		"nvim" \
		"rofi" \
		"dwm" \
		"hyprland" |
	dmenu -p "Edit config:"
)

[ -z "$choice" ] && exit 0

case "$choice" in
	kitty)
		target="$HOME/.config/kitty/kitty.conf"
		;;
	zsh)
		target="$HOME/.zshrc"
		;;
	nvim)
		target="$HOME/.config/nvim"
		;;
	rofi)
		target="$HOME/.config/rofi"
		;;
	dwm)
		target="$HOME/.config/dwm"
		;;
	hyprland)
		target="$HOME/.config/hypr"
		;;
	*)
		exit 1
		;;
esac

if printf '%s' "$TERMINAL" | grep -q alacritty; then
	"$TERMINAL" --working-directory "$(dirname "$target")" -e nvim "$target"
else
	"$TERMINAL" -d "$(dirname "$target")" -e nvim "$target"
fi
