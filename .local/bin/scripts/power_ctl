#!/bin/bash

opts="вЏ» Shutdown
о«’ Reboot
пЂЈ Suspend"

chs=$(printf "%s\n" "$opts" | dmenu -p "What do you want to do?")

case "${chs#* }" in
    Shutdown)
        systemctl poweroff
        ;;
    Reboot)
        systemctl reboot
        ;;
    Suspend)
        systemctl suspend
        ;;
    *)
        exit 0
        ;;
esac
