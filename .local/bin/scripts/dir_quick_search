#!/bin/bash

declare -A folders=(
    [.local]="$HOME/.local"
    [download]="$HOME/down"
    [images]="$HOME/img"
    [docs]="$HOME/docs"
    [videos]="$HOME/vids"
    [code]="$HOME/code"
    [music]="$HOME/msc"
    [bin]="$HOME/.local/bin"
    [share]="$HOME/.local/share"
)

options=""
for key in "${!folders[@]}"; do
    options+="$key\n"
done

esc=$(echo -e "$options" | dmenu -p "Go to:" | xargs)
[[ -z "$esc" ]] && exit 0

target="${folders[$esc]}"
[[ -z "$target" ]] && exit 0

# Special case: code drills down into projects
if [[ "$esc" == "code" ]]; then
    dir=$(for d in "$HOME/code"/*/; do
        basename "$d"
    done | dmenu -p "Project:")
    [[ -z "$dir" ]] && exit 0
    target="$HOME/code/$dir"
fi

$TERMINAL -d $target
