#!/bin/bash

THEME="$HOME/.config/rofi/noctalia-theme.rasi"

get_icon() {
    local name="$1"
    icon=$(find /usr/share/icons ~/.local/share/icons -name "${name}.png" -o -name "${name}.svg" 2>/dev/null | head -1)
    if [[ -n "$icon" ]]; then
        echo "$name"
    else
        echo "folder"
    fi
}

options=".local\0icon\x1f$(get_icon folder)\ndownload\0icon\x1f$(get_icon folder-download)\nimages\0icon\x1f$(get_icon folder-pictures)\ndocs\0icon\x1f$(get_icon folder-documents)\nvideos\0icon\x1f$(get_icon folder-videos)\ncode\0icon\x1f$(get_icon folder-development)\nmusic\0icon\x1f$(get_icon folder-music)\nbin\0icon\x1f$(get_icon folder)\nshare\0icon\x1f$(get_icon folder)"

esc=$(echo -e "$options" | rofi -dmenu -p "Go to" -theme "$THEME" | xargs)

case "${esc#* }" in
    .local)
        esc="$HOME/.local"
        ;;
    download)
        esc="$HOME/down"
        ;;
    images)
        esc="$HOME/img"
        ;;
    docs)
        esc="$HOME/docs"
        ;;
    videos)
        esc="$HOME/vids"
        ;;
    code)
	dir=$(for d in "$HOME/code"/*/; do
	    name=$(basename "$d")
	    icon=$(get_icon "$name")
	    printf '%s\0icon\x1f%s\n' "$name" "$icon"
	done | rofi -dmenu -p "Project" -theme "$THEME")
		[[ -z "$dir" ]] && exit 0
        esc="$HOME/code/$dir"
        ;;
    music)
        esc="$HOME/msc"
        ;;
    bin)
        esc="$HOME/.local/bin"
        ;;
    share)
        esc="$HOME/.local/share"
        ;;
    *)
        exit 0
        ;;
esac

$TERMINAL --working-directory="$esc"
