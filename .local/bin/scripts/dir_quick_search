#!/bin/sh

choice=$(
	printf "%s\n" \
		".local" \
		"download" \
		"images" \
		"docs" \
		"videos" \
		"code" \
		"music" \
		"bin" \
		"share" |
	dmenu -p "Go to:"
)

[ -z "$choice" ] && exit 0

case "$choice" in
	.local)  target="$HOME/.local" ;;
	download) target="$HOME/down" ;;
	images) target="$HOME/img" ;;
	docs) target="$HOME/docs" ;;
	videos) target="$HOME/vids" ;;
	music) target="$HOME/msc" ;;
	bin) target="$HOME/.local/bin" ;;
	share) target="$HOME/.local/share" ;;
	code)
		project=$(
			find "$HOME/code" -mindepth 1 -maxdepth 1 -type d \
				-exec basename {} \; |
			sort |
			dmenu -p "Project:"
		)

		[ -z "$project" ] && exit 0
		target="$HOME/code/$project"
		;;
	*)
		exit 1
		;;
esac

if [ "$TERMINAL" = "alacritty" ]; then
	alacritty --working-directory "$target" &
else
	"$TERMINAL" -d "$target" &
fi
