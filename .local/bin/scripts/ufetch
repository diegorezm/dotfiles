#!/bin/bash 
# my slightly modified version of ufetch

## INFO

host="$(cat /etc/hostname)"
os='Arch Linux'
kernel="$(uname -sr | sed 's/-.*//g')"
uptime="$(uptime -p | sed 's/up //')"
packages="$(pacman -Q | wc -l)"
shell="$(basename "${SHELL}")"
editor="$(printenv | grep "EDITOR" | cut -d '/' -f3 | sed 's/EDITOR=//g')"
browser="$(printenv | grep "BROWSER" | sed 's/BROWSER=//g')"

## UI DETECTION
parse_rcs() {
	for f in "${@}"; do
		wm="$(tail -n 1 "${f}" 2> /dev/null | cut -d ' ' -f 2)"
		[ -n "${wm}" ] && echo "${wm}" && return
	done
}

rcwm="$(parse_rcs "${HOME}/.xinitrc" "${HOME}/.xsession")"

ui='unknown'
uitype='UI'
if [ -n "${DE}" ]; then
	ui="${DE}"
	uitype='DE'
elif [ -n "${WM}" ]; then
	ui="${WM}"
	uitype='WM'
elif [ -n "${XDG_CURRENT_DESKTOP}" ]; then
	ui="${XDG_CURRENT_DESKTOP}"
	uitype='DE'
elif [ -n "${DESKTOP_SESSION}" ]; then
	ui="${DESKTOP_SESSION}"
	uitype='DE'
elif [ -n "${rcwm}" ]; then
	ui="${rcwm}"
	uitype='WM'
elif [ -n "${XDG_SESSION_TYPE}" ]; then
	ui="${XDG_SESSION_TYPE}"
fi

ui="$(basename "${ui}")"

## DEFINE COLORS

# probably don't change these
if [ -x "$(command -v tput)" ]; then
	bold="$(tput bold 2> /dev/null)"
	black="$(tput setaf 0 2> /dev/null)"
	red="$(tput setaf 1 2> /dev/null)"
	green="$(tput setaf 2 2> /dev/null)"
	yellow="$(tput setaf 3 2> /dev/null)"
	blue="$(tput setaf 4 2> /dev/null)"
	magenta="$(tput setaf 5 2> /dev/null)"
	cyan="$(tput setaf 6 2> /dev/null)"
	white="$(tput setaf 7 2> /dev/null)"
	reset="$(tput sgr0 2> /dev/null)"
fi

#colors
lc="${reset}${bold}${white}"         # labels
nc="${reset}${bold}${red}"         # user and hostname
ic="${reset}"                       # info
c0="${reset}${gray}"                # first color

## OUTPUT

cat <<EOF
в Җ${c0}в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЎ в Өв ”в ’в ’в ’в ’в Ів ӨвЈ„вЎҖ
в Җ${c0}в Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЎҙв ҡв Ғв ҖвўҖвЈӨвЈ¶вЈ¶вЈҝвЈҝвЈҝвЈҝвЈ¶вЈҜвЈ’в ӨвЈҖ      
в Җ${c0}в Җв Җв Җв Җв Җв Җв ҖвЈ°в Ӣв Җв ҖвўҖвЈҙвЈҝвЈҝвЈҝвЈҝв ҝв ҹв ӣв ҝв ҝвЈҝвЈҝвЈ·вЎҲв івЎҖ    ${nc} в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ@${USER}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${ic}${reset}
в Җ${c0}в Җв Җв Җв Җв Җв ҖвЎјв Ғв Җв Җвў вЈҝвЈҝвЈҝв ҹв үв Җв Җв Җв Җв Җв Җв Җвўүв »вЈҝв Җв №вЎҖ       ${lc}OS:        ${ic}${os}${reset}
в Җ${c0}в Җв Җв Җв Җв ҖвЈјв Үв Җв Җв ҖвўҫвЈҝвЎҝв ғв Җв Җв Җв Җв Җв Җв Җв ҖвЎҖвЈјвЈҮв ҳв Үв ҖвЈјвЎ„      ${lc}UPTIME:    ${ic}${uptime}${reset}
в Җ${c0}в Җв Җв Җв ҖвўёвЎ№в Җв Җв Җв ҖвўёвЈҝв Ғв Җв Җв Җв Җв Җв ҖвўҖвЎ„вўҖвЈҫвЈҝвЈҝвЎҶвЎҖв Җв ҲвЎҮ      ${lc}PACKAGES:  ${ic}${packages}${reset}
в Җ${c0}в Җв Җв Җв Җвўёв Үвў в Җв Җв Җв Җв Үв Җв Җв Җвў в Ҷв ҖвЈ в ҺвЈ вЈҝвЈҝвЈҝвЈҝвЈ·вўҒв Ҷв ҖвЎҮ      ${lc}SHELL:     ${ic}${shell}${reset}
в Җ${c0}в Җв Җв Җв Җвўёв Җв ҲвЎҶв Җв Җв Җв Җв Җв ҖвЈҶвЈҮвЈӨвЈҫвЎ·в ҝв ҹвЎҝвЈҝвЈҝвЈҝвЈ§в Ҡв Җв ҖвЎҮ      ${lc}${uitype}:        ${ic}${ui}${reset}
в Җ${c0}в Җв Җв Җв Җв ҖвўҮвўЈвўЎвЎ в Җв Җв Җв Җвў°вЎҝв Ӣв Ҳв Җв Җв Җвў вЈҫв ҲвЎ»вЈҝв Ғв ҖвЎҖвўҖв Ү      ${lc}KERNEL:    ${ic}${kernel}${reset}
в Җ${c0}в Җв Җв Җв Җв Җв Ҳв »вў·вЎ№вЈ·вЈ„вЎҖвЎ„вўёвЈҮвЎҖв Җв Җв Җвў вЈӨв ҖвўҖвЈјвЈҝвЎ¶вЈ°вЈҮв Һ       ${lc}EDITOR:    ${ic}${editor}${reset}
в Җ${c0}в Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв үвЈҝвЈјвЈңвЈҝвЈқвЈ¶вЈӨвЈҖвЈҖвЈЎвЈ¶вЈҝвЈҝвЈҝв ҹв ӣв Ғ        ${lc}BROWSER:   ${ic}${browser}${reset}
в Җ${c0}в Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·в Җв үв ҝв Ӣ         ${nc}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${reset}
в Җ${c0}в Җв ҖвЈ вЈ¶вЈҝвЈҝвЈҰвЈӨвЈҙвЈҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҜвЈ„в Җв ҖвЈ вЈӨвЈӨвЈ„
в Җ${c0}в ҖвЈҙвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ¶вЈҝвЈҝвЈҝвЈҝвЈ·вЈ„
в Җ${c0}вЈҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЎ„
в Җ${c0}
EOF

